# ---------------------------------------------------------------------------
# ResumeFit AI — environment configuration
# Copy this file to `.env.local` and fill in the values you need.
# Never commit `.env.local`.
# ---------------------------------------------------------------------------

# === Provider selection ====================================================
# Which provider to use for cloud tiers (economy/balanced/premium).
# One of: anthropic | openai | gemini | groq | ollama | vllm
AI_PROVIDER=anthropic

# === Per-tier models =======================================================
# The router picks a tier per task; these set the model for each tier.
# Leave blank to use sensible per-provider defaults.
# ECONOMY_MODEL   → JD/resume analysis, keyword/gap, scoring, truthfulness, interview
# BALANCED_MODEL  → default resume tailoring
# PREMIUM_MODEL   → premium/executive tailoring
# LOCAL_MODEL     → model used in Local Mode (Ollama/vLLM)
ECONOMY_MODEL=claude-haiku-4-5
BALANCED_MODEL=claude-sonnet-5
PREMIUM_MODEL=claude-opus-4-8
LOCAL_MODEL=llama3.1
# DEFAULT_MODEL is a legacy alias for BALANCED_MODEL (optional).
# DEFAULT_MODEL=claude-sonnet-5

# === Provider credentials / endpoints ======================================
# Anthropic (required when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI or any OpenAI-compatible cloud (required when AI_PROVIDER=openai)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini (OpenAI-compatible endpoint; required when AI_PROVIDER=gemini)
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Groq (required when AI_PROVIDER=groq)
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama local server (used in Local Mode, or as AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# vLLM OpenAI-compatible server (used in Local Mode, or as AI_PROVIDER=vllm)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=not-needed

# === Cost controls & monitoring ============================================
MAX_COST_PER_RUN=0.5
MAX_INPUT_TOKENS_PER_TASK=20000
MAX_OUTPUT_TOKENS_PER_TASK=8000
ENABLE_COST_LOGGING=true
ENABLE_RESPONSE_CACHE=true
# Protects GET /api/admin/usage. If unset, that endpoint is open.
ADMIN_TOKEN=

# === Database ==============================================================
# SQLite by default (zero infra). For Postgres: set provider="postgresql" in
# prisma/schema.prisma and point this at your database URL.
DATABASE_URL="file:./dev.db"

# === Authentication (Auth.js / NextAuth) ===================================
# Required. Generate one with:  node -e "console.log(require('crypto').randomBytes(33).toString('base64'))"
AUTH_SECRET=
# Google sign-in. Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (local):  http://localhost:3000/api/auth/callback/google
# Leave blank to use email/password only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Commercialization feature flags =======================================
FREE_PLAN_ENABLED=true
CREDIT_SYSTEM_ENABLED=true
SUBSCRIPTION_SYSTEM_ENABLED=true
TEAM_PLAN_ENABLED=true
WHITE_LABEL_ENABLED=false

# === Misc ==================================================================
# Legacy alias still honored as the Anthropic balanced default.
RESUMEFIT_MODEL=claude-sonnet-5
# Maximum uploaded file size in megabytes (default 8).
RESUMEFIT_MAX_FILE_MB=8
