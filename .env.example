# ---------------------------------------------------------------------------
# ResumeFit AI — environment configuration
# Copy this file to `.env.local` and fill in your key. Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Required: your Anthropic API key (server-side only, never exposed to the client).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model to use for tailoring. Defaults to claude-sonnet-5 for a good
# balance of quality, speed, and cost. You can also use claude-opus-4-8, or an
# older GA model such as claude-sonnet-4-5. Must be a model your API key has
# access to — see https://console.anthropic.com/settings/limits.
RESUMEFIT_MODEL=claude-sonnet-5

# Optional: maximum uploaded file size in megabytes (default 8).
RESUMEFIT_MAX_FILE_MB=8
